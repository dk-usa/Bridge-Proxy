{
  "name": "anthropic-openai-bridge",
  "version": "1.0.0",
  "description": "Bridge service to translate Anthropic Messages API to OpenAI-compatible APIs",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "admin-ui"
  ],
  "scripts": {
    "build": "tsc",
    "build:admin": "npm run build --workspace admin-ui",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:admin": "npm run dev --workspace admin-ui",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:admin\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.41",
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.1.1",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.2.0",
    "ioredis": "^5.10.1",
    "openai": "^4.77.0",
    "pino": "^9.6.0",
    "pino-pretty": "^11.3.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^4.1.0"
  }
}
